---
layout: null
---
[
  {% assign searchable_pages = site.pages | where_exp: "page", "page.title and page.search != false" %}
  {% for page in searchable_pages %}
    {% unless page.url == "/feed.xml" or page.url == "/search.json" %}
      {
        "title": {{ page.title | jsonify }},
        "url": {{ page.url | relative_url | jsonify }},
        "date": "",
        "tags": "",
        "content": {{ page.content | strip_html | normalize_whitespace | jsonify }}
      }{% unless forloop.last and site.posts.size == 0 %},{% endunless %}
    {% endunless %}
  {% endfor %}
  {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date | date: "%b %-d, %Y" | jsonify }},
      "tags": {{ post.tags | join: ", " | jsonify }},
      "content": {{ post.content | strip_html | normalize_whitespace | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
